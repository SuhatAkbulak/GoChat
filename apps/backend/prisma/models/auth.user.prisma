model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  role          UserRole       @default(ADMIN)
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]

  @@index([role])
  @@index([isActive])
}
