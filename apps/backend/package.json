{
  "name": "@sempeak/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "prepare:generated": "rm -rf dist/generated dist/src/generated && mkdir -p dist dist/src && cp -R src/generated dist/generated && cp -R src/generated dist/src/generated",
    "start": "nest start",
    "prestart:dev": "npm run prisma:generate && npm run prepare:generated",
    "start:dev": "bash scripts/dev-backend.sh",
    "start:prod": "node dist/main",
    "prisma:build": "rm -f prisma/schema.prisma && printf \"// DO NOT EDIT: Generated by prisma:build\\n\\n\" > prisma/schema.prisma && cat prisma/base/*.prisma prisma/models/*.prisma >> prisma/schema.prisma",
    "prisma:generate": "npm run prisma:build && prisma generate",
    "prisma:migrate:dev": "npm run prisma:build && prisma migrate dev",
    "prisma:migrate:deploy": "npm run prisma:build && prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "create:admin": "bash ./scripts/createAdmin.sh",
    "test:load:webhook": "node ./scripts/load-test-webhook.mjs",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.8",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.8",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.22",
    "@prisma/client": "^6.19.3",
    "amqplib": "^1.0.3",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.8",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.2"
  }
}