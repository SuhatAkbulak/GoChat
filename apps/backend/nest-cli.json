{
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      {
        "include": "generated/**/*",
        "outDir": "dist/generated"
      },
      {
        "include": "generated/**/*",
        "outDir": "dist/src/generated"
      }
    ],
    "watchAssets": true
  }
}
